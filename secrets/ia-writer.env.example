# iA Writer auth token for ia-attribute.sh / the MCP server.
#
# SETUP:
#   1. In iA Writer (Mac): Settings → General → URL Commands → Manage → create/copy a token.
#   2. Copy this file to `ia-writer.env` (drop the .example) IN THIS SAME `secrets/` folder.
#   3. Paste your token after the `=` below.
#
# SECURITY: this file is a secret. Never commit it, never paste its contents into
# a chat/transcript. The tooling reads it silently and never prints it.
IA_WRITER_AUTH_TOKEN=PASTE_YOUR_TOKEN_HERE
